# Local environment configuration (credentials)
# Copy this file as .env and fill in real values; .env is gitignored.

# Database
DB_HOST=localhost
DB_NAME=r4_survey
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SMTP — used by the post-test contact form (F3/F6)
# Defaults match OVH SSL endpoint. Leave SMTP_USER / SMTP_PASS empty in dev
# to disable mail sending (the controller will fail-fast with a clean error).
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=R4 — Test d'orientation
# Fallback recipient when a formation has no contact_email in DB.
MAIL_FALLBACK_TO=contact@ohvenus.fr
